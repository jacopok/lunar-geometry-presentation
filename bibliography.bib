@article{tavaniAGILEGammaRayDetection2023,
  title = {{{AGILE Gamma-Ray Detection}} of the {{Exceptional GRB 221009A}}},
  author = {Tavani, Marco and Piano, Giovanni and Bulgarelli, Andrea and Foffano, Luca and Ursi, Alessandro and Verrecchia, Francesco and Pittori, Carlotta and Casentini, Claudio and Giuliani, Andrea and Longo, Francesco and Panebianco, Gabriele and Piano, Ambra Di and Baroncelli, Leonardo and Fioretti, Valentina and Parmiggiani, Nicol\`o and Argan, Andrea and Trois, Alessio and Vercellone, Stefano and Cardillo, Martina and Antonelli, Lucio Angelo and Barbiellini, Guido and Caraveo, Patrizia and Cattaneo, Paolo W. and Chen, Andrew W. and Costa, Enrico and Monte, Ettore Del and Cocco, Guido Di and Donnarumma, Immacolata and Evangelista, Yuri and Feroci, Marco and Gianotti, Fulvio and Labanti, Claudio and Lazzarotto, Francesco and Lipari, Paolo and Lucarelli, Fabrizio and Marisaldi, Martino and Mereghetti, Sandro and Morselli, Aldo and Pacciani, Luigi and Pellizzoni, Alberto and Perotti, Francesco and Picozza, Piergiorgio and Pilia, Maura and Rapisarda, Massimo and Rappoldi, Andrea and Rubini, Alda and Soffitta, Paolo and Trifoglio, Massimo and Vittorini, Valerio and D'Amico, Fabio},
  date = {2023-10},
  journaltitle = {ApJL},

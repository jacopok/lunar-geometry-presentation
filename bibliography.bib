@article{branchesiLunarGravitationalWaveDetection2023,
  title = {Lunar {{Gravitational-Wave Detection}}},
  author = {Branchesi, Marica and Falanga, Maurizio and Harms, Jan and Jani, Karan and Katsanevas, Stavros and Lognonn\'e, Philippe and Badaracco, Francesca and Cacciapuoti, Luigi and Cappellaro, Enrico and Dell'Agnello, Simone and family=Raucourt, given=S\'ebastien, prefix=de, useprefix=true and Frigeri, Alessandro and Giardini, Domenico and Jennrich, Oliver and Kawamura, Taichi and Korol, Valeriya and Landr\o, Martin and Majstorovi\'c, Josipa and Marmat, Piyush and Mazzali, Paolo and Muccino, Marco and Patat, Ferdinando and Pian, Elena and Piran, Tsvi and Rosat, Severine and Rowan, Sheila and St\"ahler, Simon and Tissino, Jacopo},
  date = {2023-10-20},
  journaltitle = {Space Sci Rev},
  volume = {219},
  number = {8},
  pages = {67},
  issn = {1572-9672},
  doi = {10.1007/s11214-023-01015-4},
  url = {https://doi.org/10.1007/s11214-023-01015-4},
  urldate = {2023-10-20},
  abstract = {A new era of lunar exploration has begun bringing immense opportunities for science as well. It has been proposed to deploy a new generation of observatories on the lunar surface for deep studies of our Universe. This includes radio antennas, which would be protected on the far side of the Moon from terrestrial radio interference, and gravitational-wave (GW) detectors, which would profit from the extremely low level of seismic disturbances on the Moon. In recent years, novel concepts have been proposed for lunar GW detectors based on long-baseline laser interferometry or on compact sensors measuring the lunar surface vibrations caused by GWs. In this article, we review the concepts and science opportunities for such instruments on the Moon. In addition to promising breakthrough discoveries in astrophysics and cosmology, lunar GW detectors would also be formidable probes of the lunar internal structure and improve our understanding of the lunar geophysical environment.},
  langid = {english},
  keywords = {Gravitational waves,Laser interferometry,Lunar science,Seismometers},
  file = {/home/jacopo/Zotero/storage/I6HPSL89/Branchesi et al. - 2023 - Lunar Gravitational-Wave Detection.pdf}
}

@online{harmsSeismicBackgroundLimitation2022,
  title = {Seismic {{Background Limitation}} of {{Lunar Gravitational-wave Detectors}}},
  author = {Harms, Jan},
  date = {2022-05-15},
  eprint = {2205.07255},
  eprinttype = {arXiv},
  eprintclass = {gr-qc},
  doi = {10.48550/arXiv.2205.07255},
  url = {http://arxiv.org/abs/2205.07255},
  urldate = {2022-07-17},
  abstract = {New concepts were recently proposed for gravitational-wave (GW) detectors on the Moon. These include laser-interferometric detectors, proposed as free-range or optical-fiber interferometers, and inertial acceleration sensors. Some of them exploit the response of the Moon to GWs, others follow the design of current laser-interferometric GW detectors, which directly measure the gravitational strain with suspended optics. All of these ideas emerged since the Moon offers an extremely quiet geophysical environment compared to Earth, but at the same time, one must realize that even the quiet lunar environment sets limits to the sensitivity of lunar GW detectors. In this article, we compare the proposed mission concepts in terms of their response to GWs and evaluate how they are affected by the lunar seismic background. We discuss available mitigation strategies. From these analyses, we infer the prime observation band of each detector concept.},
  pubstate = {prepublished},
  keywords = {General Relativity and Quantum Cosmology},
  file = {/home/jacopo/Zotero/storage/4FRM8V7S/Harms - 2022 - Seismic Background Limitation of Lunar Gravitation.pdf;/home/jacopo/Zotero/storage/8QB4KLHB/2205.html}
}

@online{belgacemCouplingElasticMedia2024,
  title = {Coupling Elastic Media to Gravitational Waves: An Effective Field Theory Approach},
  shorttitle = {Coupling Elastic Media to Gravitational Waves},
  author = {Belgacem, Enis and Maggiore, Michele and Moreau, Thomas},
  date = {2024-03-25},
  eprint = {2403.16550},
  eprinttype = {arXiv},
  eprintclass = {astro-ph, physics:gr-qc, physics:hep-th},
  url = {http://arxiv.org/abs/2403.16550},
  urldate = {2024-03-27},
  abstract = {The interaction of a gravitational wave (GW) with an elastic body is usually described in terms of a GW "force" driving the oscillations of the body's normal modes. However, this description is only possible for GW frequencies for which the response of the elastic body is dominated by a few normal modes. At higher frequencies the normal modes blend into a quasi-continuum and a field-theoretical description, as pioneered by Dyson already in 1969, becomes necessary. However, since the metric perturbation \$h\_\{\textbackslash mu\textbackslash nu\}\$ is an intrinsically relativistic object, a consistent coupling to GWs can only be obtained within a relativistic (and, in fact generally covariant) theory of elasticity. We develop such a formalism using the methods of modern effective field theories, and we use it to provide a derivation of the interaction of elastic bodies with GWs valid also in the high-frequency regime, providing a first-principle derivation of Dyson's result (and partially correcting it). We also stress that the field-theoretical results are obtained working in the TT frame, while the description in terms of a force driving the normal modes is only valid in the proper detector frame. We show how to transform the results between the two frames. Beside an intrinsic conceptual interest, these results are relevant to the computation of the sensitivity of the recently proposed Lunar Gravitational Wave Antenna.},
  pubstate = {prepublished},
  keywords = {Astrophysics - Cosmology and Nongalactic Astrophysics,General Relativity and Quantum Cosmology,High Energy Physics - Theory},
  file = {/home/jacopo/Zotero/storage/VNS92ZWG/Belgacem et al. - 2024 - Coupling elastic media to gravitational waves an .pdf;/home/jacopo/Zotero/storage/T4GBHW68/2403.html}
}


  doi = {10.1103/PhysRevD.88.024025},
  url = {http://arxiv.org/abs/1209.0718},
  urldate = {2023-05-02},
  abstract = {Coalescing compact binary systems consisting of neutron stars and/or black holes should be detectable with upcoming advanced gravitational-wave detectors such as LIGO, Virgo, GEO and \{KAGRA\}. Gravitational-wave experiments to date have been riddled with non-Gaussian, non-stationary noise that makes it challenging to ascertain the significance of an event. A popular method to estimate significance is to time shift the events collected between detectors in order to establish a false coincidence rate. Here we propose a method for estimating the false alarm probability of events using variables commonly available to search candidates that does not rely on explicitly time shifting the events while still capturing the non-Gaussianity of the data. We present a method for establishing a statistical detection of events in the case where several silver-plated (3--5\$\textbackslash sigma\$) events exist but not necessarily any gold-plated (\${$>$}5\textbackslash sigma\$) events. We use LIGO data and a simulated, realistic, blind signal population to test our method.},
  keywords = {Astrophysics - Instrumentation and Methods for Astrophysics,General Relativity and Quantum Cosmology},
  file = {/home/jacopo/Zotero/storage/MHANICRM/Cannon et al. - 2013 - A method to estimate the significance of coinciden.pdf;/home/jacopo/Zotero/storage/SWIJRDS8/1209.html}

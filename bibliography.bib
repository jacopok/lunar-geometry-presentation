  shorttitle = {Accurate Waveforms for Eccentric, Aligned-Spin Binary Black Holes},
  author = {Gamboa, Aldo and Buonanno, Alessandra and Enficiaud, Raffi and Khalil, Mohammed and Ramos-Buades, Antoni and Pompili, Lorenzo and Estell\'es, H\'ector and Boyle, Michael and Kidder, Lawrence E. and Pfeiffer, Harald P. and R\"uter, Hannes R. and Scheel, Mark A.},
  date = {2025-08-21},

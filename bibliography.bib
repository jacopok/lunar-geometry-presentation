@article{mandelParameterEstimationCompact2014,
  title = {Parameter Estimation on Compact Binary Coalescences with Abruptly Terminating Gravitational Waveforms},
  author = {Mandel, Ilya and Berry, Christopher P L and Ohme, Frank and Fairhurst, Stephen and Farr, Will M},

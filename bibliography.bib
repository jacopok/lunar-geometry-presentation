@article{banerjeePremergerAlertDetect2023,
  title = {Pre-Merger Alert to Detect Prompt Emission in Very-High-Energy Gamma-Rays from Binary Neutron Star Mergers: {{Einstein Telescope}} and {{Cherenkov Telescope Array}} Synergy},
  shorttitle = {Pre-Merger Alert to Detect Prompt Emission in Very-High-Energy Gamma-Rays from Binary Neutron Star Mergers},
  author = {Banerjee, Biswajit and Oganesyan, Gor and Branchesi, Marica and Dupletsa, Ulyana and Aharonian, Felix and Brighenti, Francesco and Goncharov, Boris and Harms, Jan and Mapelli, Michela and Ronchini, Samuele and Santoliquido, Filippo},
  date = {2023-10-01},
  journaltitle = {A\&A},
  volume = {678},
  pages = {A126},
  publisher = {EDP Sciences},
  issn = {0004-6361, 1432-0746},
  doi = {10.1051/0004-6361/202345850},
  url = {https://www.aanda.org/articles/aa/abs/2023/10/aa45850-23/aa45850-23.html},
  urldate = {2024-06-02},
  abstract = {The current generation of very-high-energy gamma-ray (VHE; \mkbibemph{E{$<$}i/{$>$} {$>$} 30 GeV) detectors (MAGIC and H.E.S.S.) have recently demonstrated the ability to detect the afterglow emission of gamma-ray bursts (GRBs). However, the GRB prompt emission, typically observed in the 10 keV--10 MeV band, is still undetected at higher energies. Here, we investigate the perspectives of multi-messenger observations to detect the earliest VHE emission from short GRBs. Considering binary neutron star mergers as progenitors of short GRBs, we evaluate the joint detection efficiency of the Cherenkov Telescope Array (CTA) observing in synergy with the third generation of gravitational-wave detectors, such as the \mkbibemph{Einstein{$<$}i/{$>$} Telescope (ET) and Cosmic Explorer (CE). In particular, we evaluate the expected capabilities to detect and localize gravitational-wave events in the inspiral phase and to provide an early warning alert able to drive the VHE search. We compute the amount of possible joint detections by considering several observational strategies, and demonstrate that the sensitivity of CTA make the detection of the VHE emission possible even if it is several orders fainter than that observed at 10 keV--10 MeV. We discuss the results in terms of possible scenarios of the production of VHE photons from binary neutron star mergers.}}},
  langid = {english},
  file = {/home/jacopo/Zotero/storage/6PEJ7EZY/Banerjee et al. - 2023 - Pre-merger alert to detect prompt emission in very.pdf}
}


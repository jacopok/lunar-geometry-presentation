@article{evansOptimizationSwiftXray2016,
  title = {Optimization of the {{Swift X-ray}} Follow-up of {{Advanced LIGO}} and {{Virgo}} Gravitational Wave Triggers in 2015-16},
  author = {Evans, P. A. and Osborne, J. P. and Kennea, J. A. and Campana, S. and O'Brien, P. T. and Tanvir, N. R. and Racusin, J. L. and Burrows, D. N. and Cenko, S. B. and Gehrels, N.},
  date = {2016-01-01},
  journaltitle = {Monthly Notices of the Royal Astronomical Society},
  volume = {455},
  pages = {1522--1537},
  issn = {0035-8711},
  doi = {10.1093/mnras/stv2213},
  url = {https://ui.adsabs.harvard.edu/abs/2016MNRAS.455.1522E},
  urldate = {2023-01-30},
  abstract = {One of the most exciting near-term prospects in physics is the potential discovery of gravitational waves by the Advanced LIGO and Virgo detectors. To maximize both the confidence of the detection and the science return, it is essential to identify an electromagnetic counterpart. This is not trivial, as the events are expected to be poorly localized, particularly in the near-term, with error regions covering hundreds or even thousands of square degrees. In this paper, we discuss the prospects for finding an X-ray counterpart to a gravitational wave trigger with the Swift X-ray Telescope, using the assumption that the trigger is caused by a binary neutron star merger which also produces a short gamma-ray burst. We show that it is beneficial to target galaxies within the GW error region, highlighting the need for substantially complete galaxy catalogues out to distances of 300 Mpc. We also show that nearby, on-axis short GRBs are either extremely rare, or are systematically less luminous than those detected to date. We consider the prospects for detecting afterglow emission from an off-axis GRB which triggered the GW facilities, finding that the detectability, and the best time to look, are strongly dependent on the characteristics of the burst such as circumburst density and our viewing angle.},
  keywords = {Astrophysics - High Energy Astrophysical Phenomena,gamma-ray burst: general,gravitational waves,methods: observational,X-rays: general},
  annotation = {ADS Bibcode: 2016MNRAS.455.1522E},
  file = {/home/jacopo/Zotero/storage/9YYV6VW6/Evans et al. - 2016 - Optimization of the Swift X-ray follow-up of Advan.pdf}
}

@article{lhaasocollaborationDiscoveryNew$gamma$ray2021,
  title = {Discovery of a New \$\textbackslash gamma\$-Ray Source {{LHAASO J0341}}+5258 with Emission up to {{200TeV}}},
  author = {LHAASO Collaboration},
  date = {2021-08-01},
  journaltitle = {ApJL},
  volume = {917},
  number = {1},
  eprint = {2107.02020},
  eprinttype = {arXiv},
  eprintclass = {astro-ph},
  pages = {L4},
  issn = {2041-8205, 2041-8213},
  doi = {10.3847/2041-8213/ac0fd5},
  url = {http://arxiv.org/abs/2107.02020},
  urldate = {2023-10-30},
  abstract = {We report the discovery of a new unidentified extended \$\textbackslash gamma\$-ray source in the Galactic plane named LHAASO J0341+5258 with a pre-trial significance of 8.2 standard deviations above 25 TeV. The best fit position is R.A.\$=55.34\textasciicircum\{\textbackslash circ\}\textbackslash pm0.11\textasciicircum\{\textbackslash circ\}\$ and Dec\$=52.97\textasciicircum\{\textbackslash circ\}\textbackslash pm0.07\textasciicircum\{\textbackslash circ\}\$. The angular size of LHAASO J0341+5258 is \$0.29\textasciicircum\textbackslash circ \textbackslash pm 0.06\textasciicircum\textbackslash circ\_\{stat\} \textbackslash pm0.02\textasciicircum\textbackslash circ\_\{sys\}\$. The flux above 25 TeV is about \$20\textbackslash\%\$ of the flux of Crab Nebula. Although a power-law fit of the spectrum from 10 TeV to 200 TeV with the photon index \$\textbackslash alpha=2.98 \textbackslash pm 0.19\_\{stat\} \textbackslash pm 0.02\_\{sys\}\$ is not excluded, the LHAASO data together with the flux upper limit at 10 GeV set by the Fermi LAT observation, indicate a noticeable steepening of an initially hard power-law spectrum \%(\$\textbackslash alpha \textbackslash leq 1.75\$) spectrum with a cutoff at \$\textbackslash approx 50\$ TeV. We briefly discuss the origin of UHE gamma-rays. The lack of an energetic pulsar and a young SNR inside or in the vicinity of LHAASO J0341+5258 challenge, but do not exclude both the leptonic and hadronic scenarios of gamma-ray production.},
  keywords = {Astrophysics - High Energy Astrophysical Phenomena},
  file = {/home/jacopo/Zotero/storage/ILBAYVWX/LHAASO Collaboration - 2021 - Discovery of a new $gamma$-ray source LHAASO J034.pdf;/home/jacopo/Zotero/storage/LQB7UQCW/2107.html}
}


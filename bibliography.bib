}

@book{maggioreGravitationalWavesVolume2018,
  title = {Gravitational {{Waves}}: {{Volume}} 2: {{Astrophysics}} and {{Cosmology}}},
  shorttitle = {Gravitational {{Waves}}},
  author = {Maggiore, Michele},
  date = {2018-05-22},
  publisher = {Oxford University Press},
  location = {Oxford},
  abstract = {The two-volume book Gravitational Waves provides a comprehensive and detailed account of the physics of gravitational waves. While Volume 1 is devoted to the theory and experiments, Volume 2 discusses what can be learned from gravitational waves in astrophysics and in cosmology, by systematizing a large body of theoretical developments that have taken place over the last decades. The second volume also includes a detailed discussion of the first direct detections of gravitational waves. In the author's typical style, the theoretical results are generally derived afresh, clarifying or streamlining the existing derivations whenever possible, and providing a coherent and consistent picture of the field. The first volume of Gravitational Waves , which appeared in 2007, has established itself as the standard reference in the field. The scientific community has eagerly awaited this second volume. The recent direct detection of gravitational waves makes the topics in this book particularly timely.},
  isbn = {978-0-19-857089-9},
  langid = {english},
  pagetotal = {848},
  file = {/home/jacopo/Zotero/storage/2E47RQZQ/Maggiore - 2018 - Gravitational Waves Volume 2 Astrophysics and Co.pdf}
}


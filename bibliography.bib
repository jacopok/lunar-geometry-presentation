@article{damourComparisonSearchTemplates2005,
  title = {A {{Comparison}} of Search Templates for Gravitational Waves from Binary Inspiral},
  author = {Damour, Thibault and Iyer, Bala R. and Sathyaprakash, B. S.},
  date = {2005-07-12},

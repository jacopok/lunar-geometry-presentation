@online{yangSystematicBiasesGravitationalWave2026,
  title = {Systematic {{Biases}} in {{Gravitational-Wave Parameter Estimation}} from {{Neglecting Orbital Eccentricity}} in {{Space-Based Detectors}}},
  author = {Yang, Jin-Zhao and Zhong, Jia-Hao and Yang, Tao},

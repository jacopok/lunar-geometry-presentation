@online{liComplexWindowBasedJointChirpRateTimeFrequency2022,
  title = {A {{Complex Window-Based Joint-Chirp-Rate-Time-Frequency Transform}} for {{BBH Merger Gravitational Wave Signal Detection}}},
  author = {Li, Xiyuan and Houde, Martin and Valluri, S. R.},
  date = {2022-10-27},
  eprint = {2209.02673},

  shorttitle = {{{IMRPhenomXHM}}},
  author = {Garc\'ia-Quir\'os, Cecilio and Colleoni, Marta and Husa, Sascha and Estell\'es, H\'ector and Pratten, Geraint and Ramos-Buades, Antoni and Mateu-Lucena, Maite and Jaume, Rafel},

  url = {http://arxiv.org/abs/2205.09979},
  urldate = {2022-10-03},
  abstract = {Next-generation detectors are expected to be sensitive to postmerger signals from binary neutron star coalescences and thus to directly probe the remnant dynamics. We investigate the scientific potential of postmerger detections with the Einstein Telescope using full Bayesian analyses with the state-of-the-art waveform model \$\{\textbackslash tt NRPMw\}\$. We find that: (i) Postmerger signals with signal-to-noise ratio (SNR) \$\{\textbackslash sim\}7\$ can be confidently detected with a Bayes' factor of \$\textbackslash log\{\textbackslash cal B\}\textbackslash simeq 5\$ (\$\textbackslash rm e\$-folded) and the posterior distributions report informative measurements already at SNR \$\{\textbackslash sim\}6\$ for some noise realizations. (ii) The postmerger peak frequency \$f\_2\$ can be confidently identified at SNR \$7\$ with errors of \$O(1\textasciitilde\{\textbackslash rm kHz\})\$, that decrease below \$O(100\textasciitilde\{\textbackslash rm Hz\})\$ for SNR 10. (iii) The remnant's time of collapse to black hole can be constrained to \$O(20\textasciitilde\{\textbackslash rm ms\})\$ at SNR 10. However, the inference can be biased by noise fluctuationsif the latter exceed the signal's amplitude before collapse. (iv) Violations of the EOS-insentive relations for \$f\_2\$ can be detected at SNR \$\textbackslash gtrsim 8\$ if the frequency shifts are \$\textbackslash gtrsim 500\textasciitilde\{\textbackslash rm Hz\}\$; they can be smoking guns for EOS softening effects at extreme densities. However, the \$f\_2\$ measurement can be significantly biased by subdominant frequency components for short-lived remnants. In these cases, an EOS softening might be better inferred from the remnant's earlier collapse.},
  pubstate = {prepublished},
  keywords = {Astrophysics - High Energy Astrophysical Phenomena,General Relativity and Quantum Cosmology},
  file = {/home/jacopo/Zotero/storage/RK28GE9R/Breschi et al. - 2022 - Kilohertz Gravitational Waves from Binary Neutron .pdf;/home/jacopo/Zotero/storage/RL8KWTKS/2205.html}
}


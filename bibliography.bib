@article{damourFaithfulEffectiveonebodyWaveforms2007,
  title = {Faithful Effective-One-Body Waveforms of Small-Mass-Ratio Coalescing Black Hole Binaries},
  author = {Damour, Thibault and Nagar, Alessandro},
  date = {2007-09-24},
  journaltitle = {Phys. Rev. D},

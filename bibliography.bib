fix=true and family=Broeck, given=C, prefix=van den, useprefix=true and Vecchio, A and Veitch, J and Vetrano, F and Vicere, A and Vyatchanin, S and Willke, B and Woan, G and Wolfango, P and Yamamoto, K},
  date = {2010-09},
  journaltitle = {Class. Quantum Grav.},

  doi = {10.48550/arXiv.2512.01918},
  url = {http://arxiv.org/abs/2512.01918},
  urldate = {2026-03-09},
  abstract = {Tidal Love numbers of black holes, zero in classical general relativity for Kerr black holes in vacuum, become non-vanishing in the presence of exotic matter or in alternative theories of gravity, making them a powerful probe of fundamental physics. The gravitational-wave event GW250114, observed with an unprecedented signal-to-noise ratio, provides a unique opportunity to test this prediction. By analyzing this event, we conclude that the data is consistent with the binary black hole hypothesis, and we place a 90\textbackslash\% upper limit on the effective tidal deformability of \$\textbackslash tilde{$\Lambda$} {$<$} 34.8\$. These bounds imply that any environment surrounding the black holes must contribute less than \$\textbackslash sim 7\textbackslash times 10\textasciicircum\{-3\}\$ of their mass, and they rule out some models of boson stars. Our findings provide the strongest observational constraints yet on black hole tidal deformability and show that the data remain fully consistent with the Kerr black hole prediction of vanishing tidal Love numbers.},
  pubstate = {prepublished},
  keywords = {Astrophysics - High Energy Astrophysical Phenomena,General Relativity and Quantum Cosmology},
  file = {/home/jacopo/Zotero/storage/5HW6TCCF/Andrés-Carcasona and Santoro - 2025 - No Love for black holes tightest constraints on tidal Love numbers of black holes from GW250114.pdf;/home/jacopo/Zotero/storage/TMTDP7PS/2512.html}
